<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dock="clr-namespace:Dock.Avalonia.Controls;assembly=Dock.Avalonia"
        xmlns:vm="using:AuraDesigner.ViewModels"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
        x:Class="AuraDesigner.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="AuraDesigner - Professional"
        Width="1000" Height="700">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <!-- Visual Studio like background -->
    <DockPanel Background="#f3f3f3">
        <!-- Top Menu Bar -->
        <DockPanel DockPanel.Dock="Top" Background="White" LastChildFill="False">
            <Menu DockPanel.Dock="Left" BorderBrush="LightGray" BorderThickness="0,0,0,1">
                <MenuItem Header="_File">
                    <MenuItem Header="_New Project..." Command="{Binding NewProjectCommand}"/>
                    <MenuItem Header="_Open Project..." Command="{Binding OpenProjectCommand}"/>
                    <Separator/>
                    <MenuItem Header="E_xit"/>
                </MenuItem>
                <MenuItem Header="_Edit">
                    <MenuItem Header="_Undo"/>
                    <MenuItem Header="_Redo"/>
                </MenuItem>
                <MenuItem Header="_View">
                    <MenuItem Header="Solution Explorer"/>
                    <MenuItem Header="Properties Window"/>
                    <MenuItem Header="Toolbox"/>
                </MenuItem>
                <MenuItem Header="_Build">
                    <MenuItem Header="Build Solution"/>
                </MenuItem>
            </Menu>
            <!-- Search Bar mimicking VS (Ctrl+Q) -->
            <TextBox DockPanel.Dock="Right" Width="180" Height="22" Margin="0,2,10,2" 
                     Watermark="Search (Ctrl+Q)" FontSize="11" Background="#f3f3f3" 
                     BorderBrush="LightGray" CornerRadius="2" VerticalAlignment="Center">
                <TextBox.InnerRightContent>
                    <PathIcon Data="M 10 2 A 8 8 0 1 0 10 18 A 8 8 0 0 0 10 2 M 16 16 L 22 22" Width="10" Height="10" Margin="4" Foreground="DarkGray" />
                </TextBox.InnerRightContent>
            </TextBox>
        </DockPanel>

        <!-- Main Toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="#f8f8f8" Height="28" Margin="0,1,0,1">
            <Button Background="Transparent" BorderThickness="0" Margin="2,0" ToolTip.Tip="Navigate Back">
                <PathIcon Data="M 12 2 L 2 12 L 12 22 L 12 16 L 22 16 L 22 8 L 12 8 Z" Width="12" Height="12" Foreground="#005A9E" />
            </Button>
            <Button Background="Transparent" BorderThickness="0" Margin="2,0" ToolTip.Tip="Navigate Forward">
                <PathIcon Data="M 10 2 L 20 12 L 10 22 L 10 16 L 0 16 L 0 8 L 10 8 Z" Width="12" Height="12" Foreground="#005A9E" />
            </Button>
            <Separator Margin="5,4" Width="1" Background="DarkGray"/>
            
            <Button Background="Transparent" BorderThickness="0" Margin="2,0" ToolTip.Tip="New Project">
                <PathIcon Data="M 2 2 L 2 22 L 18 22 L 18 8 L 12 2 Z" Width="12" Height="12" Foreground="#107C10" />
            </Button>
            <Button Background="Transparent" BorderThickness="0" Margin="2,0" ToolTip.Tip="Open Project">
                <PathIcon Data="M 2 20 L 6 8 L 22 8 L 18 20 Z M 2 6 L 12 6 L 14 8 Z" Width="12" Height="12" Foreground="#D29200" />
            </Button>
            <Button Background="Transparent" BorderThickness="0" Margin="2,0" ToolTip.Tip="Save">
                <PathIcon Data="M 2 2 L 2 22 L 22 22 L 22 6 L 18 2 Z M 6 4 L 14 4 L 14 8 L 6 8 Z M 6 12 L 18 12 L 18 20 L 6 20 Z" Width="12" Height="12" Foreground="#005A9E" />
            </Button>
            <Button Background="Transparent" BorderThickness="0" Margin="2,0" ToolTip.Tip="Save All">
                <PathIcon Data="M 0 4 L 0 24 L 20 24 L 20 8 L 16 4 Z M 4 0 L 24 0 L 24 16 L 22 16 L 22 2 M 10 6 L 18 6 L 18 10 L 10 10 Z" Width="12" Height="12" Foreground="#005A9E" />
            </Button>
            <Separator Margin="5,4" Width="1" Background="DarkGray"/>

            <Button Background="Transparent" BorderThickness="0" Margin="2,0" ToolTip.Tip="Undo">
                <PathIcon Data="M 12 4 L 4 10 L 12 16 L 12 12 C 18 12 20 16 20 20 C 20 14 18 8 12 8 Z" Width="12" Height="12" Foreground="#005A9E" />
            </Button>
            <Button Background="Transparent" BorderThickness="0" Margin="2,0" ToolTip.Tip="Redo">
                <PathIcon Data="M 12 4 L 20 10 L 12 16 L 12 12 C 6 12 4 16 4 20 C 4 14 6 8 12 8 Z" Width="12" Height="12" Foreground="#005A9E" />
            </Button>
            <Separator Margin="5,4" Width="1" Background="DarkGray"/>

            <ComboBox SelectedIndex="0" Margin="5,2" Width="90" Height="22" FontSize="11" Padding="5,0,0,0">
                <ComboBoxItem>Debug</ComboBoxItem>
                <ComboBoxItem>Release</ComboBoxItem>
            </ComboBox>
            <ComboBox SelectedIndex="0" Margin="2,2" Width="90" Height="22" FontSize="11" Padding="5,0,0,0">
                <ComboBoxItem>Any CPU</ComboBoxItem>
                <ComboBoxItem>x64</ComboBoxItem>
                <ComboBoxItem>x86</ComboBoxItem>
            </ComboBox>

            <Button Background="Transparent" BorderThickness="0" Margin="5,0" ToolTip.Tip="Start Debugging">
                <StackPanel Orientation="Horizontal">
                    <PathIcon Data="M 4 2 L 20 12 L 4 22 Z" Width="12" Height="12" Foreground="#107C10" />
                    <TextBlock Text="AuraDesigner" VerticalAlignment="Center" Margin="5,0,0,0" FontSize="11"/>
                    <PathIcon Data="M 2 2 L 10 10 L 18 2" Width="8" Height="5" Foreground="Gray" Margin="5,4,0,0" />
                </StackPanel>
            </Button>

            <!-- Debug controls -->
            <Button Background="Transparent" BorderThickness="0" Margin="2,0" ToolTip.Tip="Break All">
                <PathIcon Data="M 6 4 L 10 4 L 10 20 L 6 20 Z M 14 4 L 18 4 L 18 20 L 14 20 Z" Width="12" Height="12" Foreground="#005A9E" />
            </Button>
            <Button Background="Transparent" BorderThickness="0" Margin="2,0" ToolTip.Tip="Stop Debugging">
                <PathIcon Data="M 4 4 L 20 4 L 20 20 L 4 20 Z" Width="12" Height="12" Foreground="#D13438" />
            </Button>
            <Button Background="Transparent" BorderThickness="0" Margin="2,0" ToolTip.Tip="Restart">
                <PathIcon Data="M 12 4 A 8 8 0 1 1 4 12 L 8 12 A 4 4 0 1 0 12 8 L 12 11 L 6 6 L 12 1 Z" Width="12" Height="12" Foreground="#005A9E" />
            </Button>

            <Separator Margin="5,4" Width="1" Background="DarkGray"/>

            <Button Background="Transparent" BorderThickness="0" Margin="2,0" ToolTip.Tip="Hot Reload">
                <PathIcon Data="M 8 22 C 6 22 4 18 4 14 C 4 8 10 2 12 2 C 12 4 16 8 16 12 C 16 8 20 6 20 6 C 20 12 16 22 8 22 Z" Width="12" Height="12" Foreground="#D13438" />
            </Button>
            <Button Background="Transparent" BorderThickness="0" Margin="2,0" ToolTip.Tip="Step Into">
                <PathIcon Data="M 12 2 L 12 16 M 8 12 L 12 16 L 16 12 M 16 22 L 8 22" Width="12" Height="12" Foreground="#005A9E" />
            </Button>
            <Button Background="Transparent" BorderThickness="0" Margin="2,0" ToolTip.Tip="Step Over">
                <PathIcon Data="M 4 14 C 4 6 18 6 18 14 M 14 10 L 18 14 L 22 10 M 12 22 L 12 16" Width="12" Height="12" Foreground="#005A9E" />
            </Button>
            <Button Background="Transparent" BorderThickness="0" Margin="2,0" ToolTip.Tip="Step Out">
                <PathIcon Data="M 12 16 L 12 2 M 8 6 L 12 2 L 16 6 M 12 22 L 12 20" Width="12" Height="12" Foreground="#005A9E" />
            </Button>

            <Separator Margin="5,4" Width="1" Background="DarkGray"/>

            <Button Background="Transparent" BorderThickness="0" Margin="2,0" ToolTip.Tip="Comment out the selected lines">
                <!-- comment lines icon -->
                <PathIcon Data="M 4 4 L 20 4 M 4 10 L 20 10 M 4 16 L 16 16 M 18 16 L 24 10 M 20 16 L 26 10" Width="12" Height="12" Foreground="#107C10" />
            </Button>
            <Button Background="Transparent" BorderThickness="0" Margin="2,0" ToolTip.Tip="Uncomment the selected lines">
                <!-- uncomment lines icon -->
                <PathIcon Data="M 4 4 L 20 4 M 4 10 L 20 10 M 4 16 L 16 16" Width="12" Height="12" Foreground="#005A9E" />
            </Button>

            <Separator Margin="5,4" Width="1" Background="DarkGray"/>
            
            <Button Background="Transparent" BorderThickness="0" Margin="2,0" ToolTip.Tip="Find">
                <PathIcon Data="M 10 2 A 8 8 0 1 0 10 18 A 8 8 0 0 0 10 2 M 16 16 L 22 22" Width="12" Height="12" Foreground="#005A9E" />
            </Button>
        </StackPanel>

        <!-- Bottom Status Bar -->
        <DockPanel DockPanel.Dock="Bottom" Background="#007acc" Height="25">
            <TextBlock Text="Ready" Foreground="White" VerticalAlignment="Center" Margin="10,0,0,0" />
            <TextBlock Text="AuraDesigner v1.0" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" DockPanel.Dock="Right"/>
        </DockPanel>

        <!-- Main Docking Area -->
        <dock:DockControl Layout="{Binding Layout}" />
    </DockPanel>
</Window>
