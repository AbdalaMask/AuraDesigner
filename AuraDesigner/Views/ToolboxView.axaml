<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AuraDesigner.ViewModels"
             x:Class="AuraDesigner.Views.ToolboxView"
             x:DataType="vm:ToolboxViewModel">
    <Grid Background="#ffffff">
        <Grid RowDefinitions="Auto, *">
            <TextBlock Grid.Row="0" Text="Standard Controls" Foreground="Black" FontWeight="Bold" Margin="10"/>
            <ListBox x:Name="ControlList" Grid.Row="1" ItemsSource="{Binding AvailableControls}" Margin="5">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="2">
                            <TextBlock Text="🧩 " />
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</UserControl>
