<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:AuraDesigner.ViewModels"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="450"
        x:Class="AuraDesigner.Views.NewProjectWindow"
        x:DataType="vm:NewProjectViewModel"
        Title="Create a New Project"
        Width="600" Height="450"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/IconTagManager.ico">

    <Grid Margin="20">
        
        <!-- STAGE 1: Template Selection -->
        <Grid RowDefinitions="Auto,*,Auto" IsVisible="{Binding !IsConfiguring}">
            <TextBlock Grid.Row="0" Text="Select a Project Template" FontSize="20" FontWeight="Bold" Margin="0,0,0,15" />
            
            <ListBox Grid.Row="1" ItemsSource="{Binding Templates}" SelectedItem="{Binding SelectedTemplate}" Margin="0,0,0,20">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="5">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="16" />
                            <TextBlock Text="{Binding ShortName}" Opacity="0.7" FontSize="12" Margin="0,2,0,0" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Command="{Binding CancelCommand}" Margin="0,0,10,0" Width="80" HorizontalContentAlignment="Center"/>
                <Button Content="Next" Command="{Binding NextCommand}" IsEnabled="{Binding SelectedTemplate, Converter={x:Static ObjectConverters.IsNotNull}}" Classes="accent" Width="80" HorizontalContentAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- STAGE 2: Project Configuration -->
        <Grid RowDefinitions="Auto,*,Auto" IsVisible="{Binding IsConfiguring}">
            <TextBlock Grid.Row="0" Text="Configure your new project" FontSize="20" FontWeight="Bold" Margin="0,0,0,15" />

            <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*,Auto" Margin="0,10,0,0" VerticalAlignment="Top">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Project Name:" VerticalAlignment="Center" Margin="0,0,10,10"/>
                <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding ProjectName}" Margin="0,0,0,10"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Location:" VerticalAlignment="Center" Margin="0,0,10,10"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ProjectLocation}" Margin="0,0,10,10"/>
                <Button Grid.Row="1" Grid.Column="2" Content="Browse..." Command="{Binding BrowseCommand}" Margin="0,0,0,10"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Language:" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding AvailableLanguages}" SelectedItem="{Binding SelectedLanguage}" Width="100"/>
            </Grid>
            
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Back" Command="{Binding BackCommand}" Margin="0,0,10,0" Width="80" HorizontalContentAlignment="Center"/>
                <Button Content="Create" Command="{Binding CreateCommand}" IsEnabled="{Binding !IsBusy}" Classes="accent" Width="80" HorizontalContentAlignment="Center"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
