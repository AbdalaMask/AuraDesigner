<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AuraDesigner.ViewModels"
             x:Class="AuraDesigner.Views.SolutionExplorerView"
             x:DataType="vm:SolutionExplorerViewModel">
    <Grid Background="#ffffff">
        <TreeView Margin="5" ItemsSource="{Binding RootNodes}">
            <TreeView.ItemTemplate>
                <TreeDataTemplate ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal" Margin="2">
                        <TextBlock Text="📄 " IsVisible="{Binding IsFile}" />
                        <TextBlock Text="📁 " IsVisible="{Binding !IsFile}" />
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                    </StackPanel>
                </TreeDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</UserControl>
