<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AuraDesigner.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="200"
             x:Class="AuraDesigner.Views.ErrorListView"
             x:DataType="vm:ErrorListViewModel">

    <Grid RowDefinitions="Auto,*">
        <!-- Toolbar Strip for Error List -->
        <Border Grid.Row="0" Background="#f3f3f3" BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5,2">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <ToggleButton IsChecked="True" BorderThickness="0" Background="Transparent" Padding="4">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <PathIcon Data="M 12 2 C 6.48 2 2 6.48 2 12 C 2 17.52 6.48 22 12 22 C 17.52 22 22 17.52 22 12 C 22 6.48 17.52 2 12 2 Z M 13 17 L 11 17 L 11 15 L 13 15 L 13 17 Z M 13 13 L 11 13 L 11 7 L 13 7 L 13 13 Z" Width="12" Height="12" Foreground="#D13438"/>
                        <TextBlock Text="0 Errors" FontSize="12"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton IsChecked="True" BorderThickness="0" Background="Transparent" Padding="4">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <PathIcon Data="M 1 21 L 12 2 L 23 21 Z M 13 18 L 11 18 L 11 16 L 13 16 Z M 13 14 L 11 14 L 11 10 L 13 10 Z" Width="12" Height="12" Foreground="#D29200"/>
                        <TextBlock Text="0 Warnings" FontSize="12"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton IsChecked="True" BorderThickness="0" Background="Transparent" Padding="4">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <PathIcon Data="M 12 2 C 6.48 2 2 6.48 2 12 C 2 17.52 6.48 22 12 22 C 17.52 22 22 17.52 22 12 Z M 13 17 L 11 17 L 11 11 L 13 11 Z M 13 9 L 11 9 L 11 7 L 13 7 Z" Width="12" Height="12" Foreground="#005A9E"/>
                        <TextBlock Text="0 Messages" FontSize="12"/>
                    </StackPanel>
                </ToggleButton>
                
                <Separator Width="1" Background="LightGray" Margin="2,0"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Errors}" AutoGenerateColumns="False" BorderThickness="0"
                  GridLinesVisibility="All" Background="White" RowBackground="White">
            <DataGrid.Columns>
                <DataGridTemplateColumn Width="30">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:ErrorListItem">
                            <PathIcon Data="M 12 2 C 6.48 2 2 6.48 2 12 C 2 17.52 6.48 22 12 22 C 17.52 22 22 17.52 22 12 C 22 6.48 17.52 2 12 2 Z M 13 17 L 11 17 L 11 15 L 13 15 L 13 17 Z M 13 13 L 11 13 L 11 7 L 13 7 L 13 13 Z" Width="12" Height="12" Foreground="#D13438" Margin="8,0,0,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="80"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="Project" Binding="{Binding Project}" Width="150"/>
                <DataGridTextColumn Header="File" Binding="{Binding File}" Width="150"/>
                <DataGridTextColumn Header="Line" Binding="{Binding Line}" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
