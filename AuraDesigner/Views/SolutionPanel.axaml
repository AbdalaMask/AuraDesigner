<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AuraDesigner.Views.SolutionPanel">
    <Grid Background="#ffffff">
        <TreeView Margin="5">
            <TreeViewItem Header="Solution 'AuraDesigner'">
                <TreeViewItem Header="AuraDesigner" IsExpanded="True">
                    <TreeViewItem Header="App.axaml" />
                    <TreeViewItem Header="MainWindow.axaml" />
                </TreeViewItem>
            </TreeViewItem>
        </TreeView>
    </Grid>
</UserControl>
