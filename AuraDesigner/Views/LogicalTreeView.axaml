<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AuraDesigner.ViewModels"
             xmlns:models="using:AuraDesigner.Core.Models"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="400"
             x:Class="AuraDesigner.Views.LogicalTreeView"
             x:DataType="vm:LogicalTreeViewModel">
  <Grid RowDefinitions="Auto, *">
    <TextBlock Grid.Row="0" Text="Logical Tree" FontWeight="SemiBold" Margin="10,5" />
    
    <TreeView Grid.Row="1" 
              ItemsSource="{Binding RootNodes}"
              SelectedItem="{Binding SelectedItem}"
              Background="Transparent" BorderThickness="0">
      <TreeView.ItemTemplate>
        <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="models:IDesignItem">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="📦" Margin="0,0,5,0" FontSize="12" VerticalAlignment="Center" />
            <TextBlock Text="{Binding ComponentType.Name}" VerticalAlignment="Center" />
            <TextBlock Text="{Binding Name, StringFormat=' ({0})'}" 
                       IsVisible="{Binding Name, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" 
                       Opacity="0.5" FontSize="11" Margin="5,0,0,0" VerticalAlignment="Center" />
          </StackPanel>
        </TreeDataTemplate>
      </TreeView.ItemTemplate>
      
      <TreeView.Styles>
        <Style Selector="TreeViewItem">
          <Setter Property="IsExpanded" Value="True" />
        </Style>
      </TreeView.Styles>
    </TreeView>
  </Grid>
</UserControl>
