<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AuraDesigner.Views.PropertiesView">
    <Grid Background="#ffffff">
        <StackPanel Margin="10">
            <TextBlock Text="Properties" Foreground="Black" FontWeight="Bold" Margin="0,0,0,10"/>
            <!-- Placeholder for property grid -->
            <Grid ColumnDefinitions="100, *" RowDefinitions="Auto, Auto, Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" Foreground="Black" VerticalAlignment="Center" Margin="5"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="Button1" Margin="5"/>
                
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Width:" Foreground="Black" VerticalAlignment="Center" Margin="5"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="100" Margin="5"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Height:" Foreground="Black" VerticalAlignment="Center" Margin="5"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="30" Margin="5"/>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
