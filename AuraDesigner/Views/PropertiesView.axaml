<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AuraDesigner.ViewModels"
             x:DataType="vm:PropertiesViewModel"
             x:Class="AuraDesigner.Views.PropertiesView">
    <Grid Background="#ffffff">
        <StackPanel Margin="10">
            <TextBlock Text="{Binding SelectedObjectName, StringFormat='{}Properties ({0})'}" Foreground="Black" FontWeight="Bold" Margin="0,0,0,10"/>
            
            <ScrollViewer VerticalScrollBarVisibility="Auto" Height="800">
                <ItemsControl ItemsSource="{Binding Properties}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="120, *" RowDefinitions="Auto" Margin="0,5">
                                <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="Black" VerticalAlignment="Center" Margin="5"/>
                                <TextBox Grid.Column="1" Text="{Binding Value, Mode=TwoWay}" Margin="5"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>
    </Grid>
</UserControl>
